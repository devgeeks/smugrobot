{
  "name": "@smugrobot/notes",
  "version": "0.7.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc --noEmit && vite build",
    "preview": "vite build --mode preview && vite preview",
    "deploy": "npm run build && rsync -avz --delete -e \"ssh\" dist/* tommy@smugrobot.com:/home/tommy/apache-vhosts/smugrobot.com/public_html/notes",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@milkdown/core": "^7.21.3",
    "@milkdown/ctx": "^7.21.3",
    "@milkdown/plugin-clipboard": "^7.21.3",
    "@milkdown/plugin-history": "^7.21.3",
    "@milkdown/plugin-listener": "^7.21.3",
    "@milkdown/preset-commonmark": "^7.21.3",
    "@milkdown/preset-gfm": "^7.21.3",
    "@milkdown/transformer": "^7.21.3",
    "@milkdown/utils": "^7.21.3",
    "@smugrobot/ui": "*",
    "echidna.js": "*",
    "escape-html": "^1.0.3",
    "scrypt-js": "^3.0.1"
  },
  "devDependencies": {
    "@types/escape-html": "^1.0.4",
    "@vite-pwa/assets-generator": "^1.0.2",
    "typescript": "*",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^1.3.0"
  }
}
